// Test 1: Generic function - identity
function identity<T>(T value): T {
    return value;
}

// Test 2: Generic class - Box
class Box<T> {
    private:
        T stored;

    public:
        Box(T value) {
            stored = value;
        }

        function get(): T {
            return stored;
        }
}

// Test 3: Generic function with constraint
interface IPrintable {
    function label(): string;
}

class Tag : IPrintable {
    private:
        string text;

    public:
        Tag(string t) {
            text = t;
        }

        function label(): string {
            return text;
        }
}

function printLabel<T where T : IPrintable>(T item): void {
    print(item.label());
}

function main(): void {
    // Test generic function - int
    int x = identity<int>(42);
    print(x);

    // Test generic function - string
    string s = identity<string>("hello generics");
    print(s);

    // Test generic class with int
    Box<int> box = new Box<int>(99);
    print(box.get());

    // Test generic class with string
    Box<string> sbox = new Box<string>("boxed");
    print(sbox.get());

    // Test constrained generic function
    Tag tag = new Tag("my-tag");
    printLabel<Tag>(tag);
}
