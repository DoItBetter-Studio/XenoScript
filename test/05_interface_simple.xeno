interface IGreeter {
    function greet(): void;
}

class Greeter : IGreeter {
    function greet(): void {
        print("hello");
    }
}

function main(): void {
    // No currently supported.
    // IGreeter g = new Greeter();

    // This however, is currently supported.
    Greeter g = new Greeter();
    g.greet();
}
