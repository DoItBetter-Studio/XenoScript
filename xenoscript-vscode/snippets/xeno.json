{
  "Function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:params}): ${3:void} {", "    ${0}", "}"],
    "description": "Define a function"
  },

  "If Statement": {
    "prefix": "if",
    "body": ["if (${1:condition}) {", "    ${0}", "}"],
    "description": "If statement"
  },

  "If Else Statement": {
    "prefix": "ife",
    "body": ["if (${1:condition}) {", "    ${2}", "} else {", "    ${0}", "}"],
    "description": "If/Else statement"
  },

  "While Loop": {
    "prefix": "while",
    "body": ["while (${1:condition}) {", "    ${0}", "}"],
    "description": "While loop"
  },

  "For Loop": {
    "prefix": "for",
    "body": [
      "for (${1:i} = ${2:0}; ${1} < ${3:count}; ${1} = ${1} + 1) {",
      "    ${0}",
      "}"
    ],
    "description": "For loop"
  },

  "Match Statement": {
    "prefix": "match",
    "body": [
      "match (${1:value}) {",
      "    case ${2:pattern}: {",
      "        ${0}",
      "    }",
      "    default: {",
      "    }",
      "}"
    ],
    "description": "Match expression"
  },

  "Class": {
    "prefix": "class",
    "body": ["class ${1:Name} {", "    ${0}", "}"],
    "description": "Class declaration"
  },

  "Enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "    ${0}", "}"],
    "description": "Enum declaration"
  },

  "New Array": {
    "prefix": "newarr",
    "body": ["new ${1:type}[${2:size}]"],
    "description": "Allocate a new array"
  },

  "Constructor": {
    "prefix": "ctor",
    "body": ["${1:ClassName}() {", "    ${0}", "}"],
    "description": "Constructor"
  }
}
